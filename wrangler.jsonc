{
  "$schema": "./config-schema.json",
  "name": "mcbe-download",
  "compatibility_date": "2026-6-20",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "build": {
    "watch_dir": "./src",
    "command": "pnpm build"
  },
  "routes": [
    {
      "pattern": "mcd.wei.qzz.io/*",
      "zone_name": "wei.qzz.io"
    }
  ]
}